generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum CategoryKind {
  POST
  UPDATE
}

enum AssetKind {
  IMAGE
  VIDEO
  FILE
}

enum AssetProvider {
  S3
  R2
  LOCAL
}

enum CommentStatus {
  PENDING
  APPROVED
  SPAM
}

enum UserRole {
  USER
  ADMIN
  OWNER
}

enum SubscriberStatus {
  PENDING
  ACTIVE
  UNSUBSCRIBED
}

enum MailJobStatus {
  PENDING
  PROCESSING
  SENT
  FAILED
}

enum MailJobKind {
  POST_PUBLISHED
  UPDATE_PUBLISHED
}

enum MailJobContentType {
  POST
  UPDATE
}

enum StandalonePageNavGroup {
  HOME
  MORE
}

enum UpdateKind {
  NOTE
  MOVIE
  MUSIC
  OBJECT
}

enum FriendLinkApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum BookmarkKind {
  DOCS
  ARTICLE
  TOOL
  COLLECTION
}

model Post {
  id                Int           @id @default(autoincrement())
  title             String
  slug              String        @unique
  summary           String?
  status            ContentStatus @default(DRAFT)
  content           Json?
  contentHtml       String?
  authorName        String?
  publishedAt       DateTime?
  subscriptionEmailSentAt DateTime?
  commentsEnabled   Boolean       @default(true)
  publishedSnapshot Json?
  draftSnapshot     Json?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  viewCount         Int           @default(0)
  categoryId        Int?
  coverAssetId      String?
  category          Category?     @relation("PostCategory", fields: [categoryId], references: [id], onDelete: SetNull)
  coverAsset        Asset?        @relation("PostCoverAsset", fields: [coverAssetId], references: [id], onDelete: SetNull)
  tags              PostTag[]
  views             PostView[]
  likes             PostLike[]
  comments          PostComment[]

  @@index([status, publishedAt])
  @@index([categoryId])
}

model PostView {
  id        String   @id @default(cuid())
  postId    Int
  visitorId String
  bucket    String
  viewedAt  DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, visitorId, bucket])
  @@index([postId])
  @@index([visitorId])
}

model PostLike {
  id        String   @id @default(cuid())
  postId    Int
  visitorId String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, visitorId])
  @@index([postId])
  @@index([visitorId])
}

model SiteLike {
  id        String   @id @default(cuid())
  visitorId String   @unique
  createdAt DateTime @default(now())

  @@index([visitorId])
}

model User {
  id            String        @id @default(cuid())
  username      String?       @unique
  passwordHash  String?
  name          String?
  email         String?       @unique
  emailVerified DateTime?     @map("email_verified")
  image         String?
  githubUrl     String?
  socialLinks   Json?
  role          UserRole      @default(USER)
  accounts      Account[]
  sessions      Session[]
  comments      PostComment[]

  @@map("users")
}

model PostComment {
  id               String          @id @default(cuid())
  postId           Int?
  standalonePageId Int?
  parentId         String?
  threadRootId     String?
  userId           String?
  authorName       String?
  authorEmail      String?
  body             String          @db.Text
  status           CommentStatus   @default(PENDING)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  post             Post?           @relation(fields: [postId], references: [id], onDelete: Cascade)
  standalonePage   StandalonePage? @relation(fields: [standalonePageId], references: [id], onDelete: Cascade)
  parent           PostComment?    @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies          PostComment[]   @relation("CommentReplies")
  threadRoot       PostComment?    @relation("CommentThread", fields: [threadRootId], references: [id], onDelete: Cascade)
  threadReplies    PostComment[]   @relation("CommentThread")
  user             User?           @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([postId, status, createdAt])
  @@index([standalonePageId, status, createdAt])
  @@index([parentId])
  @@index([threadRootId])
  @@index([userId])
}

model Account {
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
  @@map("verification_tokens")
}

model PublicInteractionSettings {
  id                     String   @id @default("default")
  commentsEnabled        Boolean  @default(false)
  subscriptionsEnabled   Boolean  @default(true)
  subscriptionConfirmSubject String?
  subscriptionConfirmHeadline String?
  subscriptionConfirmBody String?
  subscriptionConfirmCtaLabel String?
  postNotificationSubject String?
  postNotificationHeadline String?
  postNotificationBody String?
  postNotificationCtaLabel String?
  updateNotificationSubject String?
  updateNotificationHeadline String?
  updateNotificationBody String?
  updateNotificationCtaLabel String?
  loginRequiredToComment Boolean  @default(true)
  commentModeration      Boolean  @default(true)
  githubLoginEnabled     Boolean  @default(true)
  authSecret             String?
  githubClientId         String?
  githubClientSecret     String?
  googleLoginEnabled     Boolean  @default(false)
  googleClientId         String?
  googleClientSecret     String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model Update {
  id            Int           @id @default(autoincrement())
  title         String
  authorName    String?
  status        ContentStatus @default(DRAFT)
  kind          UpdateKind    @default(NOTE)
  content       Json?
  contentHtml   String?
  metadata      Json?
  publishedAt   DateTime?
  subscriptionEmailSentAt DateTime?
  draftSnapshot Json?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([status, publishedAt])
}

model StandalonePage {
  id              Int                    @id @default(autoincrement())
  title           String
  slug            String                 @unique
  status          ContentStatus          @default(DRAFT)
  content         Json?
  contentHtml     String?
  publishedAt     DateTime?
  commentsEnabled Boolean                @default(false)
  draftSnapshot   Json?
  showInNav       Boolean                @default(false)
  navLabel        String?
  navEyebrow      String?
  navGroup        StandalonePageNavGroup @default(HOME)
  seoTitle        String?
  seoDescription  String?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  comments        PostComment[]

  @@index([status, publishedAt])
  @@index([showInNav, navGroup, status, publishedAt])
}

model FriendLink {
  id           Int                     @id @default(autoincrement())
  name         String
  url          String
  description  String?
  avatarUrl    String?
  location     String?
  feedUrl      String?
  email        String?
  sortOrder    Int                     @default(0)
  isVisible    Boolean                 @default(true)
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
  applications FriendLinkApplication[]

  @@index([isVisible, sortOrder, updatedAt])
}

model FriendLinkApplication {
  id           Int                         @id @default(autoincrement())
  nickname     String?
  siteName     String
  siteUrl      String
  description  String?
  avatarUrl    String?
  rssUrl       String?
  contactEmail String
  message      String?
  status       FriendLinkApplicationStatus @default(PENDING)
  reviewedAt   DateTime?
  friendLinkId Int?
  createdAt    DateTime                    @default(now())
  updatedAt    DateTime                    @updatedAt
  friendLink   FriendLink?                 @relation(fields: [friendLinkId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([friendLinkId])
}

model Bookmark {
  id         Int              @id @default(autoincrement())
  title      String
  url        String
  logoUrl    String?
  summary    String
  note       String?
  categoryId Int
  kind       BookmarkKind
  tags       String[]         @default([])
  sortOrder  Int              @default(0)
  isVisible  Boolean          @default(true)
  isFeatured Boolean          @default(false)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  category   BookmarkCategoryItem @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@index([isVisible, categoryId, sortOrder, updatedAt])
  @@index([isFeatured, isVisible, updatedAt])
  @@index([categoryId])
}

model BookmarkCategoryItem {
  id          Int        @id @default(autoincrement())
  name        String
  slug        String     @unique
  eyebrow     String?
  description String?
  sortOrder   Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  bookmarks   Bookmark[]

  @@index([sortOrder, name])
}

model Asset {
  id         String        @id @default(cuid())
  provider   AssetProvider
  kind       AssetKind
  storageKey String        @unique
  bucket     String?
  url        String
  title      String?
  alt        String?
  photoMeta  String?
  mimeType   String?
  size       Int?
  width      Int?
  height     Int?
  duration   Int?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  postCovers Post[]        @relation("PostCoverAsset")
}

model ObjectStorageSettings {
  id              String        @id @default("default")
  provider        AssetProvider @default(R2)
  endpoint        String?
  region          String        @default("auto")
  bucket          String
  accessKeyId     String
  secretAccessKey String
  publicBaseUrl   String
  keyPrefix       String?
  forcePathStyle  Boolean       @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model EmailSettings {
  id                  String   @id @default("default")
  smtpHost            String
  smtpPort            Int
  smtpSecure          Boolean  @default(false)
  smtpUser            String
  smtpPass            String
  smtpFromEmail       String
  smtpFromName        String?
  subscriptionReplyTo String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model MailJob {
  id              String              @id @default(cuid())
  kind            MailJobKind
  status          MailJobStatus       @default(PENDING)
  contentType     MailJobContentType
  contentId       Int
  recipientEmail  String
  dedupeKey       String              @unique
  payload         Json
  scheduledAt     DateTime            @default(now())
  lockedAt        DateTime?
  lastAttemptAt   DateTime?
  processedAt     DateTime?
  attemptCount    Int                 @default(0)
  maxAttempts     Int                 @default(5)
  lastError       String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([status, scheduledAt, createdAt])
  @@index([contentType, contentId, status])
  @@index([recipientEmail, status])
}

model Subscriber {
  id                  String           @id @default(cuid())
  email               String           @unique
  status              SubscriberStatus @default(PENDING)
  confirmToken        String           @unique
  unsubscribeToken    String           @unique
  subscribedToPosts   Boolean          @default(true)
  subscribedToUpdates Boolean          @default(true)
  confirmedAt         DateTime?
  unsubscribedAt      DateTime?
  lastEmailSentAt     DateTime?
  source              String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  @@index([status, createdAt])
}

model Category {
  id          Int          @id @default(autoincrement())
  kind        CategoryKind
  name        String
  slug        String
  description String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  posts       Post[]       @relation("PostCategory")

  @@unique([kind, slug])
  @@index([kind, name])
}

model Tag {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  posts     PostTag[]
}

model PostTag {
  postId     Int
  tagId      String
  assignedAt DateTime @default(now())
  post       Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@index([tagId])
}

model SiteSettings {
  id                                   String   @id @default("default")
  siteName                             String
  siteDescription                      String
  siteUrl                              String
  locale                               String   @default("zh-CN")
  authorName                           String
  authorAvatarUrl                      String?
  siteSubtitle                         String?
  heroIntro                            String?
  summary                              String?
  motto                                String?
  email                                String?
  githubUrl                            String?
  tmdbApiKey                           String?
  movieSource                          String?
  musicSource                          String?
  projectsGitHubUsername               String?
  hiddenProjectSlugs                   String[] @default([])
  siteLiveVisitorsEnabled              Boolean  @default(true)
  postReadingPresenceEnabled           Boolean  @default(true)
  standalonePageReadingPresenceEnabled Boolean  @default(true)
  createdAt                            DateTime @default(now())
  updatedAt                            DateTime @updatedAt
}

model AdminUser {
  id           String         @id @default(cuid())
  username     String         @unique
  passwordHash String
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  sessions     AdminSession[]

  @@ignore
}

model AdminSession {
  id        String    @id @default(cuid())
  token     String    @unique
  expiresAt DateTime
  createdAt DateTime  @default(now())
  userId    String
  user      AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@ignore
}
