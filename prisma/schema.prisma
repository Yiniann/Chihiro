generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum CategoryKind {
  POST
  UPDATE
}

enum AssetKind {
  IMAGE
  VIDEO
  FILE
}

enum AssetProvider {
  S3
  R2
  LOCAL
}

enum CommentStatus {
  PENDING
  APPROVED
  SPAM
}

enum UserRole {
  USER
  ADMIN
  OWNER
}

enum SubscriberStatus {
  PENDING
  ACTIVE
  UNSUBSCRIBED
}

enum StandalonePageNavGroup {
  HOME
  MORE
}

model Post {
  id                Int           @id @default(autoincrement())
  title             String
  slug              String        @unique
  summary           String?
  status            ContentStatus @default(DRAFT)
  content           Json?
  contentHtml       String?
  authorName        String?
  publishedAt       DateTime?
  publishedSnapshot Json?
  draftSnapshot     Json?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  viewCount         Int           @default(0)
  categoryId        Int?
  coverAssetId      String?
  category          Category?     @relation("PostCategory", fields: [categoryId], references: [id], onDelete: SetNull)
  coverAsset        Asset?        @relation("PostCoverAsset", fields: [coverAssetId], references: [id], onDelete: SetNull)
  tags              PostTag[]
  views             PostView[]
  likes             PostLike[]
  comments          PostComment[]

  @@index([status, publishedAt])
  @@index([categoryId])
}

model PostView {
  id        String   @id @default(cuid())
  postId    Int
  visitorId String
  bucket    String
  viewedAt  DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, visitorId, bucket])
  @@index([postId])
  @@index([visitorId])
}

model PostLike {
  id        String   @id @default(cuid())
  postId    Int
  visitorId String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, visitorId])
  @@index([postId])
  @@index([visitorId])
}

model User {
  id            String        @id @default(cuid())
  username      String?       @unique
  passwordHash  String?
  name          String?
  email         String?       @unique
  emailVerified DateTime?     @map("email_verified")
  image         String?
  githubUrl     String?
  socialLinks   Json?
  role          UserRole      @default(USER)
  accounts      Account[]
  sessions      Session[]
  comments      PostComment[]

  @@map("users")
}

model PostComment {
  id            String        @id @default(cuid())
  postId        Int
  parentId      String?
  threadRootId  String?
  userId        String?
  authorName    String?
  authorEmail   String?
  body          String        @db.Text
  status        CommentStatus @default(PENDING)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  post          Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  parent        PostComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies       PostComment[] @relation("CommentReplies")
  threadRoot    PostComment?  @relation("CommentThread", fields: [threadRootId], references: [id], onDelete: Cascade)
  threadReplies PostComment[] @relation("CommentThread")
  user          User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([postId, status, createdAt])
  @@index([parentId])
  @@index([threadRootId])
  @@index([userId])
}

model Account {
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
  @@map("verification_tokens")
}

model PublicInteractionSettings {
  id                     String   @id @default("default")
  commentsEnabled        Boolean  @default(false)
  subscriptionsEnabled   Boolean  @default(true)
  loginRequiredToComment Boolean  @default(true)
  commentModeration      Boolean  @default(true)
  githubLoginEnabled     Boolean  @default(true)
  authSecret             String?
  githubClientId         String?
  githubClientSecret     String?
  googleLoginEnabled     Boolean  @default(false)
  googleClientId         String?
  googleClientSecret     String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model Update {
  id            Int           @id @default(autoincrement())
  title         String
  authorName    String?
  status        ContentStatus @default(DRAFT)
  content       Json?
  contentHtml   String?
  publishedAt   DateTime?
  draftSnapshot Json?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([status, publishedAt])
}

model StandalonePage {
  id             Int                    @id @default(autoincrement())
  title          String
  slug           String                 @unique
  status         ContentStatus          @default(DRAFT)
  content        Json?
  contentHtml    String?
  publishedAt    DateTime?
  draftSnapshot  Json?
  showInNav      Boolean                @default(false)
  navLabel       String?
  navEyebrow     String?
  navGroup       StandalonePageNavGroup @default(HOME)
  seoTitle       String?
  seoDescription String?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  @@index([status, publishedAt])
  @@index([showInNav, navGroup, status, publishedAt])
}

model Asset {
  id         String        @id @default(cuid())
  provider   AssetProvider
  kind       AssetKind
  storageKey String        @unique
  bucket     String?
  url        String
  title      String?
  alt        String?
  photoMeta  String?
  mimeType   String?
  size       Int?
  width      Int?
  height     Int?
  duration   Int?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  postCovers Post[]        @relation("PostCoverAsset")
}

model ObjectStorageSettings {
  id              String        @id @default("default")
  provider        AssetProvider @default(R2)
  endpoint        String?
  region          String        @default("auto")
  bucket          String
  accessKeyId     String
  secretAccessKey String
  publicBaseUrl   String
  keyPrefix       String?
  forcePathStyle  Boolean       @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model EmailSettings {
  id                   String   @id @default("default")
  smtpHost             String
  smtpPort             Int
  smtpSecure           Boolean  @default(false)
  smtpUser             String
  smtpPass             String
  smtpFromEmail        String
  smtpFromName         String?
  subscriptionReplyTo  String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model Subscriber {
  id                String           @id @default(cuid())
  email             String           @unique
  status            SubscriberStatus @default(PENDING)
  confirmToken      String           @unique
  unsubscribeToken  String           @unique
  subscribedToPosts Boolean          @default(true)
  subscribedToUpdates Boolean        @default(true)
  confirmedAt       DateTime?
  unsubscribedAt    DateTime?
  lastEmailSentAt   DateTime?
  source            String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([status, createdAt])
}

model Category {
  id          Int          @id @default(autoincrement())
  kind        CategoryKind
  name        String
  slug        String
  description String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  posts       Post[]       @relation("PostCategory")

  @@unique([kind, slug])
  @@index([kind, name])
}

model Tag {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  posts     PostTag[]
}

model PostTag {
  postId     Int
  tagId      String
  assignedAt DateTime @default(now())
  post       Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@index([tagId])
}

model SiteSettings {
  id              String   @id @default("default")
  siteName        String
  siteDescription String
  siteUrl         String
  locale          String   @default("zh-CN")
  authorName      String
  authorAvatarUrl String?
  heroIntro       String?
  summary         String?
  motto           String?
  email           String?
  githubUrl       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model AdminUser {
  id           String         @id @default(cuid())
  username     String         @unique
  passwordHash String
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  sessions     AdminSession[]

  @@ignore
}

model AdminSession {
  id        String    @id @default(cuid())
  token     String    @unique
  expiresAt DateTime
  createdAt DateTime  @default(now())
  userId    String
  user      AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@ignore
}
